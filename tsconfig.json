{
  "compilerOptions": {
    "target": "es2019",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "types": ["jest", "node"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}